{
  "name": "@talkietalker/stream-react",
  "version": "0.1.0",
  "description": "TalkieTalker Stream React SDK for live rooms and broadcast players",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./room": {
      "types": "./dist/room/index.d.ts",
      "import": "./dist/room/index.js"
    },
    "./signaling": {
      "types": "./dist/signaling/index.d.ts",
      "import": "./dist/signaling/index.js"
    },
    "./webrtc": {
      "types": "./dist/webrtc/index.d.ts",
      "import": "./dist/webrtc/index.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "ladle": "ladle serve",
    "analyze": "tsup && node scripts/report-bundle-size.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@ladle/react": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
